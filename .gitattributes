# デフォルトはテキストとして扱い、改行を自動正規化（LF を採用）
* text=auto eol=lf

# Windows 専用ファイルは CRLF を維持
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.ps1xml    text eol=crlf
*.iss       text eol=crlf
*.nsi       text eol=crlf
*.nsh       text eol=crlf

# バイナリ（diff 不要 / 改行変換しない）
